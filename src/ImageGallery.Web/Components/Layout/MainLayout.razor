@inherits LayoutComponentBase
@using ImageGallery.Web.App.Services
@inject AuthStateService AuthState
@implements IDisposable

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudDrawer Open="drawerOpen" Variant="DrawerVariant.Responsive">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6" Class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" />
                ImageGallery
            </MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudAppBar>
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                           OnClick="@((e) => drawerOpen = !drawerOpen)" />
            <MudText Typo="Typo.h6" Class="ms-2">ImageGallery</MudText>
            <MudSpacer />
            @if (AuthState.IsAuthenticated)
            {
                <MudText Class="mr-2" Typo="Typo.body2">Signed in</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                               OnClick="@HandleLogout" />
            }
            else
            {
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit"
                               href="/login" />
            }
        </MudAppBar>

        <div class="mt-16">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool drawerOpen = true;

    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += StateHasChanged;
    }

    private void HandleLogout()
    {
        AuthState.Logout();
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= StateHasChanged;
    }
}
